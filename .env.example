# =============================================================================
# E-GAOP Environment Variables — Copy to .env and fill in
# =============================================================================

# ─── TLS / mTLS ──────────────────────────────────────────────────────────────
TLS_ENABLED=true
TLS_CERT_DIR=/etc/egaop/certs

# ─── API Server ──────────────────────────────────────────────────────────────
API_SERVER_GRPC_PORT=50051
API_SERVER_REST_PORT=3001
API_SERVER_HEALTH_PORT=15051

# ─── LLM Router ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
LLM_FALLBACK_CHAIN=gpt-4o,gpt-4o-mini,gpt-3.5-turbo
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
RATE_LIMIT_LLM_RPM=30

# ─── Tool Proxy ─────────────────────────────────────────────────────────────
RATE_LIMIT_TOOL_PROXY_RPM=60

# ─── Sandbox Runtime ────────────────────────────────────────────────────────
SANDBOX_RUNTIME_PORT=50054
SANDBOX_RUNTIME_HEALTH_PORT=15054
DOCKER_HOST=unix:///var/run/docker.sock

# ─── Memory Plane ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
POSTGRES_USER=egaop
POSTGRES_PASSWORD=egaop_dev
POSTGRES_DB=egaop

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=egaop-agent-queue

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=egaop
LOG_LEVEL=info

# ─── Secrets ────────────────────────────────────────────────────────────────
EGAOP_MASTER_ENCRYPTION_KEY=dev-key-do-not-use-in-production

# ─── Grafana ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# =============================================================================
# The Kubernetes of AI Agents — Environment Variables
# =============================================================================
# Copy to .env and fill with real values. NEVER commit .env
#   cp .env.example .env
#
# Generate secrets:
#   openssl rand -hex 32          # for 64-char hex key
#   openssl rand -base64 32       # for base64 key
#
# CI/CD NOTE: In GitHub Actions, secrets are injected as environment
# variables directly — NEVER written to .env files on disk.
# Only non-secret values (IMAGE_TAG, REGISTRY, LOG_LEVEL, etc.) go to .env.
# =============================================================================

# ─── TLS / mTLS ──────────────────────────────────────────────────────────────
TLS_ENABLED=true
TLS_CERT_DIR=/etc/egaop/certs

# ─── API Server ──────────────────────────────────────────────────────────────
API_SERVER_GRPC_PORT=50051
API_SERVER_REST_PORT=3001
API_SERVER_HEALTH_PORT=15051

# ─── LLM Router ─────────────────────────────────────────────────────────────
# [REQUIRED] API key (OpenAI, Groq, OpenRouter, etc.)
OPENAI_API_KEY=
# [OPTIONAL] Base URL (default: OpenAI). Use Groq: https://api.groq.com/openai/v1
OPENAI_BASE_URL=
# Fallback chain (comma-separated). Groq models: llama3-8b-8192,llama3-70b-8192,mixtral-8x7b-32768
LLM_FALLBACK_CHAIN=llama3-8b-8192,llama3-70b-8192,mixtral-8x7b-32768
LLM_TIMEOUT_MS=30000
LLM_MAX_RETRIES=3
RATE_LIMIT_LLM_RPM=30

# ─── Tool Proxy ─────────────────────────────────────────────────────────────
RATE_LIMIT_TOOL_PROXY_RPM=60

# ─── Sandbox Runtime ────────────────────────────────────────────────────────
SANDBOX_RUNTIME_PORT=50054
SANDBOX_RUNTIME_HEALTH_PORT=15054
DOCKER_HOST=unix:///var/run/docker.sock

# ─── Memory Plane ───────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379

# ─── PostgreSQL ─────────────────────────────────────────────────────────────
# [REQUIRED] Use a strong password — never the default in production
POSTGRES_USER=egaop
POSTGRES_PASSWORD=
POSTGRES_DB=egaop

# ─── Temporal ───────────────────────────────────────────────────────────────
TEMPORAL_HOST=temporal
TEMPORAL_PORT=7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=egaop-agent-queue

# ─── JWT Authentication ─────────────────────────────────────────────────────
# [REQUIRED] Secret for signing/verifying JWT tokens
# Generate with: openssl rand -hex 32
JWT_SECRET=

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=egaop
LOG_LEVEL=info

# ─── Secrets ────────────────────────────────────────────────────────────────
# [REQUIRED] 32-byte random key for AES-256-GCM encryption
# Generate with: openssl rand -hex 32
EGAOP_MASTER_ENCRYPTION_KEY=
# [REQUIRED] Shared token for gRPC service-to-service auth (x-service-token)
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# ─── Grafana ────────────────────────────────────────────────────────────────
# [REQUIRED] Use a strong password — never "admin" in production
GRAFANA_USER=admin
GRAFANA_PASSWORD=
# [OPTIONAL] Slack incoming webhook for Grafana alert notifications
# https://api.slack.com/messaging/webhooks
SLACK_ALERT_WEBHOOK=

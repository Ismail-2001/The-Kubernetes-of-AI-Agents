{
  "name": "@k8s-ai-agents/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "The Kubernetes of AI Agents — Production-grade orchestration for LLM-powered agents at scale",
  "workspaces": [
    "packages/shared",
    "control-plane/api-server",
    "control-plane/secret-store",
    "control-plane/workflow-engine",
    "execution-plane/llm-router",
    "execution-plane/tool-proxy",
    "execution-plane/sandbox-runtime",
    "memory-plane",
    "observability-plane",
    "policy-plane"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w control-plane/api-server\" \"npm run dev -w control-plane/secret-store\" \"npm run dev -w execution-plane/llm-router\" \"npm run dev -w execution-plane/sandbox-runtime\" \"npm run dev -w execution-plane/tool-proxy\" \"npm run dev -w memory-plane\" \"npm run dev -w observability-plane\"",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.13",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "concurrently": "^9.1.0",
    "eslint": "^10.7.0",
    "jest": "^29.7.0",
    "pg": "^8.22.0",
    "ts-jest": "^29.3.0",
    "testcontainers": "^12.0.4",
    "typescript": "^5.7.0"
  }
}

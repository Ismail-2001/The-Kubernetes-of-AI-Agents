# Dependencies
**/node_modules
**/.pnp
**/.pnp.js

# Testing
**/coverage/

# Next.js
**/.next/
**/out/

# Build output
**/dist/
**/build/

# Local env files
.env
.env.*
!.env.example

# Secrets directory (never commit real secrets)
secrets/
!secrets/.gitkeep

# Private keys and certificates (NEVER commit private keys)
*.pem
*.key
certs/*.pem
certs/*.srl

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# TypeScript
*.tsbuildinfo
**/next-env.d.ts

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Protobuf Generated
api/generated/

# Go build
bin/
pkg/
vendor/

# Jest
**/jest.config.js

# Vercel
.vercel

# Backup artifacts (test archives, not source)
backups/

# k6 load test results (keep gitkeep for dir structure)
tests/load/results/*.json
tests/load/results/*.tar.gz

# Temporary files
tmp/
charts/e-gaop/tmpcharts*/

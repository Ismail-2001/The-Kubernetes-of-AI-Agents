{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }, "unit": "reqps" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Request Rate",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(http_requests_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "req/s" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Error Rate",
      "type": "stat",
      "targets": [
        { "expr": "sum(rate(http_requests_total{namespace=\"$namespace\", status=~\"5..\"}[$__rate_interval])) / sum(rate(http_requests_total{namespace=\"$namespace\"}[$__rate_interval])) * 100", "legendFormat": "%" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 500 }] }, "unit": "ms" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "P95 Latency",
      "type": "stat",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{namespace=\"$namespace\"}[$__rate_interval])) by (le))", "legendFormat": "ms" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 10 }] }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "area", "justifyMode": "auto", "orientation": "auto", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "title": "Active Agents",
      "type": "stat",
      "targets": [
        { "expr": "active_agents{namespace=\"$namespace\"}", "legendFormat": "" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 7 },
      "id": 200,
      "title": "Request Latency Distribution",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "none" } }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 8 },
      "id": 10,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Latency by Service",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(grpc_request_duration_ms_bucket{namespace=\"$namespace\"}[$__rate_interval])) by (le, rpc_service))", "legendFormat": "{{ rpc_service }} P50" },
        { "expr": "histogram_quantile(0.95, sum(rate(grpc_request_duration_ms_bucket{namespace=\"$namespace\"}[$__rate_interval])) by (le, rpc_service))", "legendFormat": "{{ rpc_service }} P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(grpc_request_duration_ms_bucket{namespace=\"$namespace\"}[$__rate_interval])) by (le, rpc_service))", "legendFormat": "{{ rpc_service }} P99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 300,
      "title": "Agent Execution",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "normal" } }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 20,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Agent Executions by Status",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(agent_execution_total{namespace=\"$namespace\", status=\"success\"}[$__rate_interval]))", "legendFormat": "success" },
        { "expr": "sum(rate(agent_execution_total{namespace=\"$namespace\", status=\"failed\"}[$__rate_interval]))", "legendFormat": "failed" },
        { "expr": "sum(rate(agent_execution_total{namespace=\"$namespace\", status=\"timeout\"}[$__rate_interval]))", "legendFormat": "timeout" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "none" } }, "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 21,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "Tool Execution Latency",
      "type": "timeseries",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(tool_execution_duration_ms_bucket{namespace=\"$namespace\"}[$__rate_interval])) by (le, tool_name))", "legendFormat": "{{ tool_name }} P95" },
        { "expr": "histogram_quantile(0.99, sum(rate(tool_execution_duration_ms_bucket{namespace=\"$namespace\"}[$__rate_interval])) by (le, tool_name))", "legendFormat": "{{ tool_name }} P99" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 400,
      "title": "LLM & Tokens",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "none" } }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 30,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "LLM Tokens Used",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(llm_tokens_used{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "tokens/s" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 500,
      "title": "Policy Plane",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "none" } }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 40,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "OPA Evaluations",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(opa_evaluate_total{namespace=\"$namespace\"}[$__rate_interval]))", "legendFormat": "evaluations/s" },
        { "expr": "sum(rate(opa_evaluate_total{namespace=\"$namespace\", decision=\"allow\"}[$__rate_interval]))", "legendFormat": "allow/s" },
        { "expr": "sum(rate(opa_evaluate_total{namespace=\"$namespace\", decision=\"deny\"}[$__rate_interval]))", "legendFormat": "deny/s" }
      ]

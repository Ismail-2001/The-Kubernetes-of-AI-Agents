    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 10, "lineWidth": 2, "stacking": { "mode": "none" } }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] }, "tooltip": { "mode": "multi" } },
      "title": "OPA Cache Hit Rate",
      "type": "timeseries",
      "targets": [
        { "expr": "sum(rate(opa_cache_hit_total{namespace=\"$namespace\"}[$__rate_interval])) / sum(rate(opa_evaluate_total{namespace=\"$namespace\"}[$__rate_interval])) * 100", "legendFormat": "cache hit %" }
      ]
    }
  ],
